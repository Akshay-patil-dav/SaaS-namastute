# ─────────────────────────────────────────────────────────────────────────────
#  Namustute POS — Environment Variables
#  Copy this file to .env and fill in your real values.
#  This file is used by docker-compose.yml
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=otp_auth_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

# ── Backend URLs ──────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# ── Frontend Build Vars (embedded into Vite bundle at build time) ─────────────
VITE_API_BASE_URL=http://localhost:3000/api
VITE_BACKEND_BASE_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:5173

# ── OAuth2 (optional — leave blank if not using Google/Facebook login) ────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
